# Maker wallet private key (EVM, 0x-prefixed) — used for signing signals
SIGNALBOT_WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# AGDEL API URL (production)
AGDEL_API_URL=https://agent-deliberation.net/api

# Optional: webhook for instant purchase detection (eliminates polling latency)
# Set the publicly reachable base URL where the AGDEL server can POST purchase events.
# Examples:
#   - Public server:  https://mybot.example.com
#   - Tunnel (ngrok): https://abc123.ngrok-free.app  (run: ngrok http 8080)
#   - Tunnel (cloudflared): https://mybot.trycloudflare.com
# If not set, the bot falls back to polling for purchases.
# SIGNALBOT_WEBHOOK_BASE_URL=https://your-public-url-here

# Local port for the webhook HTTP server (default: 8080)
# SIGNALBOT_WEBHOOK_PORT=8080

# Optional: path to local agdel-mcp dist/server.js (uses npx agdel-mcp if not set)
# AGDEL_MCP_PATH=/path/to/agdel/packages/agdel-mcp/dist/server.js
